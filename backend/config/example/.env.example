# Chameleon 部署级 env override（sage 风格重构后）
#
# 这里**只放部署级 override**——大部分配置已在配置文件里：
#   - AI 相关（LLM key + URL）  → config/model.json
#   - DB / Redis 连接信息       → config/component.json
#   - 业务参数（log_level 等）   → config/chameleon.json
#   - 外部 agent 平台 URL       → config/baseurl.json
#   - 外部 agent 注册           → config/agents.yaml
#
# 本文件只在以下情况要填：
# - 容器化 / 多实例部署时，环境变量临时 override JSON 配置
# - agents.yaml 用 ${env:XXX} 占位符引用某个 key（如 DIFY_FAQ_KEY）

# 雪花 ID 实例号（多实例部署必须不同；单机默认 0 即可）
CHAMELEON_INSTANCE_ID=0

# ── 安全相关（dev 留空，启动自动用 demo；生产必填） ──
# 部署环境标记：production 时缺以下 key/secret 会启动 fail-fast
# CHAMELEON_ENV=production

# AES-256-GCM 主密钥（base64 32 字节）—— 加密 providers.api_key 等敏感字段
# 生成：python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# CHAMELEON_CRYPTO_KEY=

# JWT secret（base64 ≥ 32 字节）—— 签 access_token / refresh_token
# 生成同上
# CHAMELEON_JWT_SECRET=

# ── 部署级 override（按需开） ──
# LOG_LEVEL=DEBUG
# DATABASE_URL=postgresql+asyncpg://user:pwd@host:5432/chameleon

# ── agents.yaml 引用的外部 agent api_key（按需） ──
# DIFY_FAQ_KEY=app-xxxxxx
# FASTGPT_ORDER_KEY=fastgpt-xxxxxx
