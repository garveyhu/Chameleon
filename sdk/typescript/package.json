{
  "name": "@chameleon/sdk",
  "version": "0.1.0",
  "description": "Chameleon TS/JS SDK — LLMops tracing",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": "https://github.com/garveyhu/Chameleon"
}
