# Chameleon 环境变量（实例化时 cp 到 ../.env 并改）
# 本机 PG 共享实例：见 /Users/links/Environment/Docker/postgres/

DATABASE_URL=postgresql+asyncpg://collector:030317Archer@127.0.0.1:8103/chameleon
REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=INFO

# LLM provider API keys（按需填）
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# 外部 agent provider keys（按需填，与 config/agents.yaml 里的 api_key_env 对应）
# DIFY_FAQ_KEY=
# FASTGPT_ORDER_KEY=

# 雪花 ID 实例号（多实例部署时区分；单机默认 0）
CHAMELEON_INSTANCE_ID=0
