# ─────────────────────────────────────────────────────────────
# Chameleon 镜像 tag —— build / push / 本地 compose 的唯一来源
#
# 用法：
#   cp .env.example .env
#   修改 _TAG 值，由 docker/scripts/build-images.sh 读取
# ─────────────────────────────────────────────────────────────

CHAMELEON_VERSION=0.1.0

CHAMELEON_BASE_TAG=0.1.0
CHAMELEON_CODE_TAG=0.1.0
CHAMELEON_UI_TAG=0.1.0
