# syntax=docker/dockerfile:1.7
#
# chameleon-code —— 后端源码 + 迁移 + alembic.ini （data-only 镜像）
#
# 关键设计：
#   - FROM busybox:musl，只产 /export/* 目录，run-local 时由 code-init 容器 cp 进 named volume
#   - 不含 .venv（走 chameleon-venv 镜像）
#   - 不含系统运行时（走 chameleon-base 镜像）
#
# 变更频率：每次代码 push。镜像体积小（几十 MB），CI 推送快

FROM busybox:musl

# 后端各子包源码
COPY backend/chameleon-core/src              /export/chameleon-core/src
COPY backend/chameleon-providers/base/src    /export/chameleon-providers/base/src
COPY backend/chameleon-providers/local/src   /export/chameleon-providers/local/src
COPY backend/chameleon-providers/dify/src    /export/chameleon-providers/dify/src
COPY backend/chameleon-providers/fastgpt/src /export/chameleon-providers/fastgpt/src
COPY backend/chameleon-api/src               /export/chameleon-api/src
COPY backend/chameleon-system/src            /export/chameleon-system/src
COPY backend/chameleon-app/src               /export/chameleon-app/src

# agent 包整体拷贝（含 examples）
COPY backend/chameleon-agents                /export/chameleon-agents

# 各子包 pyproject.toml —— alembic 等运行时可能要读
COPY backend/chameleon-core/pyproject.toml              /export/chameleon-core/
COPY backend/chameleon-providers/base/pyproject.toml    /export/chameleon-providers/base/
COPY backend/chameleon-providers/local/pyproject.toml   /export/chameleon-providers/local/
COPY backend/chameleon-providers/dify/pyproject.toml    /export/chameleon-providers/dify/
COPY backend/chameleon-providers/fastgpt/pyproject.toml /export/chameleon-providers/fastgpt/
COPY backend/chameleon-api/pyproject.toml               /export/chameleon-api/
COPY backend/chameleon-system/pyproject.toml            /export/chameleon-system/
COPY backend/chameleon-app/pyproject.toml               /export/chameleon-app/

# 根 pyproject + lock（启动期 chameleon 命令需要）
COPY backend/pyproject.toml backend/uv.lock /export/

# 迁移文件 + alembic 配置
COPY backend/alembic.ini   /export/alembic.ini
COPY backend/migrations    /export/migrations
