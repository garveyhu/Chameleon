# ─────────────────────────────────────────────────────────────
# Chameleon 部署运行时配置
#
# 用法：cp .env.example .env  → 改 PG/Redis/JWT/Crypto 等敏感值
# docker compose 会自动加载同级 .env
# ─────────────────────────────────────────────────────────────

# ── 镜像 tag（从 docker/images/.env 同步） ──────────────
REGISTRY_PREFIX=chameleon
CHAMELEON_BASE_TAG=latest
CHAMELEON_VENV_TAG=latest
CHAMELEON_CODE_TAG=latest
CHAMELEON_UI_TAG=latest

# ── PostgreSQL ────────────────────────────────────────────
PG_DB=chameleon
PG_USER=chameleon
# !!! 部署前务必改 !!! 弱密码会被扫描到
PG_PASSWORD=change-this-pg-password
PG_HOST_PORT=5432

# ── Redis ─────────────────────────────────────────────────
# !!! 部署前务必改 !!!
REDIS_PASSWORD=change-this-redis-password
REDIS_HOST_PORT=6379

# ── 安全密钥 ──────────────────────────────────────────────
# 生成方式：python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
# !!! 部署前务必改 !!! 用默认值起服务会被强制 fail
CHAMELEON_JWT_SECRET=GENERATE_ME_WITH_secrets.token_bytes_32_b64
CHAMELEON_CRYPTO_KEY=GENERATE_ME_WITH_secrets.token_bytes_32_b64

# ── 应用 ──────────────────────────────────────────────────
LOG_LEVEL=INFO
CHAMELEON_LOG_LEVEL=info
CHAMELEON_WORKERS=2
CHAMELEON_INSTANCE_ID=0
TZ=Asia/Shanghai

# ── 端口（host 暴露） ─────────────────────────────────────
BACKEND_HOST_PORT=7009
UI_HOST_PORT=6006
