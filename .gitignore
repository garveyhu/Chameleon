# 配置（敏感 + 实例化）—— 见 docs/getting-started.md 四点五节
# .gitignore 不支持行内注释，每条规则单独占一行

# 部署级 env override
backend/config/.env

# 业务参数
backend/config/chameleon.json

# AI 全包（含 LLM api_key）—— sage 风格
backend/config/model.json

# 中间件连接（含 DB password 等）
backend/config/component.json

# 外部 agent 注册（含 app_id 等）
backend/config/agents.yaml

# baseurl.json 一般不含秘钥，按需放行；如需隐藏，取消下一行注释
# backend/config/baseurl.json

# 资源 / 数据
backend/resources/
backend/logs/
*.log

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# 多 agent 并行：git worktree 子目录（4 个 agent 各一个 branch + 工作区）
.worktrees/

# Docker 三区运行时数据 / 凭据（绝不入 git）
docker/containers/data/
docker/containers/.env
docker/containers/prod/.env
docker/images/.env
docker/scripts/.registry.env
